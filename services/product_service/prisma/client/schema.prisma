generator client {
  provider = "prisma-client-js"
  output   = "./client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL_PRODUCT")
}

model Product {
  id        Int      @id @default(autoincrement())
  name      String
  price     Float
  category  String
  size      String // S, M, L
  color     String
  brand     String
  stock     Int      @default(0)
  imageUrl  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
