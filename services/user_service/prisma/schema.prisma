generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL_USER")
}

model User {
  id           Int       @id @default(autoincrement())
  name         String?
  email        String    @unique
  password     String?
  role         String    @default("USER")
  googleId     String?   @unique
  provider     String    @default("email") // "email" or "google"
  otpCode      String?   // Hashed OTP
  otpExpires   DateTime? // Expiry timestamp
  otpAttempts  Int       @default(0)
  otpLastSent  DateTime? // Cooldown checking
  refreshToken String?   // Session refresh token
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}
